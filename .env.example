# =============================================================================
# GUIDE - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- OpenAI API ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_2=your_openai_api_key_2_here
OPENAI_BASE_URL=https://api.openai.com/

# --- Qwen API (DashScope) ---
OPENAI_QWEN_API_KEY=your_dashscope_api_key_here
OPENAI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-azure-endpoint.openai.azure.com/

# --- Doubao / ByteDance Seed model ---
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3

# --- YouTube & Google Search ---
YOUTUBE_API_KEY=your_youtube_api_key_here
GOOGLE_CSE_CX=your_custom_search_engine_cx_here
GOOGLE_CSE_KEY=your_google_api_key_here

# --- OSWorld Evaluation ---
OSWORLD_BASE_URL=http://your_server_ip:your_port
OSWORLD_TOKEN=your_osworld_token_here
